# This Gemfile is only needed if you want to PREVIEW the site locally.
# GitHub Pages builds the site for you without it.
#
# To preview locally (requires Ruby): run `bundle install` then
#   bundle exec jekyll serve
# and open http://localhost:4000

source "https://rubygems.org"

# Matches the GitHub Pages build environment.
gem "github-pages", group: :jekyll_plugins

# Lock down for Ruby 3+ compatibility during local preview.
gem "webrick", "~> 1.8"
